{
  "expo": {
    "name": "Mobile Starter",
    "slug": "expo-supabase-revenuecat-starter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "mobile-starter",
    "ios": {
      "bundleIdentifier": "com.yourcompany.mobilestarter",
      "supportsTablet": true,
      "usesAppleSignIn": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-splash-screen",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.your-reversed-ios-client-id"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
